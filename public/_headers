*
    Cache-Control: public, max-age=3600
    Content-Security-Policy: default-src 'none'; connect-src 'self' https://tiles.openfreemap.org https://plausible.io; script-src 'self' https://plausible.io; style-src 'self'; img-src 'self' data: blob: https://tiles.openfreemap.org; manifest-src 'self'; worker-src 'self' blob:
    Permissions-Policy: geolocation=(self)
    Referrer-Policy: strict-origin-when-cross-origin
    Strict-Transport-Security: max-age=31556926; includeSubDomains
    X-Content-Type-Options: nosniff
    X-Frame-Options: SAMEORIGIN
